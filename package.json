{
  "name": "yt2x",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "YouTube to X — unified pipeline: YouTube acquisition → AI structured notes → X longform article → publish",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yt2x/yt2x.git"
  },
  "homepage": "https://github.com/yt2x/yt2x#readme",
  "bugs": {
    "url": "https://github.com/yt2x/yt2x/issues"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b --pretty",
    "clean": "pnpm -r run clean && rm -f .tsbuildinfo packages/*/.tsbuildinfo",
    "rebuild": "pnpm run clean && pnpm run build",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "ci:full": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:coverage && pnpm audit --audit-level=high",
    "pack:cli": "pnpm run build && pnpm pack --dir packages/cli",
    "yt2x": "pnpm exec tsc -b packages/cli --pretty false && tsx packages/cli/src/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@yt2x/core": "workspace:*",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.4.11",
      "esbuild": "^0.28.1",
      "js-yaml": "^4.2.0",
      "vite": "^6.4.3"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-5xrq-8626-4rwp",
        "GHSA-67mh-4wv8-2f99",
        "GHSA-4w7w-66w2-5vf9",
        "GHSA-jxxr-4gwj-5jf2",
        "GHSA-gv7w-rqvm-qjhr",
        "GHSA-fx2h-pf6j-xcff"
      ]
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
