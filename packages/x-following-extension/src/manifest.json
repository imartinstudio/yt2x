{
  "manifest_version": 3,
  "name": "X 关注列表助手",
  "version": "0.1.0",
  "description": "在 X 正在关注列表中筛选未回关用户、勾选并批量取消关注。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": ["https://x.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*/following", "https://x.com/*/following/*"],
      "js": ["content/following-manager.js"],
      "run_at": "document_idle"
    }
  ]
}
