{
  "manifest_version": 3,
  "name": "X 清道夫",
  "version": "0.2.3",
  "version_name": "0.2.3",
  "description": "清理你在 X 上的关注列表：筛选未回关用户、一键全选、批量取消关注。",
  "author": "yt2x",
  "homepage_url": "https://github.com/imartinstudio/yt2x",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/following-manager.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "X 清道夫",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
