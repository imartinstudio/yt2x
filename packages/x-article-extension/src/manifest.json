{
  "manifest_version": 3,
  "name": "yt2x X Articles Markdown Import",
  "version": "0.2.0",
  "description": "Import local Markdown into the current X Articles draft editor.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "scripting", "clipboardWrite", "clipboardRead"],
  "host_permissions": ["https://x.com/*"],
  "background": {
    "service_worker": "background/main-world-bridge.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content/x-articles.js"],
      "run_at": "document_idle"
    }
  ]
}
