{
  "name": "@yt2x/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "yt2x command-line interface.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yt2x/yt2x.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/yt2x/yt2x#readme",
  "bugs": {
    "url": "https://github.com/yt2x/yt2x/issues"
  },
  "keywords": [
    "youtube",
    "twitter",
    "x",
    "cli",
    "transcript",
    "markdown",
    "yt2x"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "yt2x": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@yt2x/core": "workspace:*",
    "@yt2x/adapters-node": "workspace:*",
    "commander": "^13.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
